[Unit]
Description=HaniPi Dashboard
After=network.target

[Service]
Type=simple
User=hanipi
AmbientCapabilities=CAP_NET_BIND_SERVICE
ExecStart=/opt/hanipi/venv/bin/uvicorn hanipi_dashboard.main:app --host 0.0.0.0 --port 80
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
